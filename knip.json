{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["src/main.tsx", "src/app/App.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/components/ui/**",
    "src/tests/**",
    "src/infrastructure/mocks/**",
    "**/*.stories.tsx",
    "**/*.test.{ts,tsx}",
    "**/*.spec.{ts,tsx}"
  ],
  "ignoreDependencies": ["@testing-library/jest-dom", "@types/node"]
}
